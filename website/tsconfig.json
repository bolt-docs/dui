{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"jsx": "react-jsx",
		"noEmit": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"baseUrl": "."
	},
	"include": ["boltdocs.config.ts", ".boltdocs/generated/types.d.ts"]
}
