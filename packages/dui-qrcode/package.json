{
	"name": "@dui-toolkit/plugin-qrcode",
	"version": "0.2.0",
	"description": "QR code generator for @bdocs/dui — render scannable QR codes directly in the terminal with ANSI blocks.",
	"main": "dist/index.mjs",
	"types": "dist/index.d.mts",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "tsdown --config-loader unrun",
		"dev": "tsdown --watch --config-loader unrun",
		"test": "vitest run"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bolt-docs/dui.git"
	},
	"keywords": [
		"terminal",
		"cli",
		"qrcode",
		"qr",
		"ansi",
		"barcode"
	],
	"packageManager": "pnpm@10.30.2",
	"license": "MIT",
	"type": "module",
	"dependencies": {
		"@bdocs/dui": "workspace:*",
		"qrcode": "^1.5.4"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@types/qrcode": "^1.5.5",
		"tsdown": "^0.21.7",
		"typescript": "^5.9.3",
		"vitest": "^3.0.0"
	}
}
