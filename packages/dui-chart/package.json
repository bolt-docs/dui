{
	"name": "@dui-toolkit/plugin-chart",
	"version": "0.3.0",
	"description": "Terminal charts — bar, column, line, pie, and sparkline charts for @bdocs/dui with animation support.",
	"main": "dist/index.mjs",
	"types": "dist/index.d.mts",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "tsdown --config-loader unrun",
		"dev": "tsdown --watch --config-loader unrun",
		"test": "vitest run"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dui-toolkit/plugin-chart.git"
	},
	"keywords": [
		"terminal",
		"cli",
		"chart",
		"bar-chart",
		"line-chart",
		"pie-chart",
		"sparkline",
		"ansi"
	],
	"packageManager": "pnpm@10.30.2",
	"license": "MIT",
	"type": "module",
	"dependencies": {
		"@bdocs/dui": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"tsdown": "^0.21.7",
		"typescript": "^5.9.3",
		"vitest": "^3.0.0"
	}
}
