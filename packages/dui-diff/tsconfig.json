{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"declaration": true,
		"outDir": "dist",
		"rootDir": "src"
	},
	"include": ["src/**/*", "src/types/**/*.d.ts"],
	"exclude": ["node_modules", "dist"]
}
